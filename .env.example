# --- Server Configuration ---
# Options: dev, prod, test
NODE_ENV=dev
PORT=3000

# --- MySQL Configuration ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=school_broadcast_db
DB_CONNECTION_LIMIT=10

# --- Redis Configuration ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# --- Logging Configuration ---
# Options: error, info, debug
LOG_LEVEL=info

# --- HTTPS Configuration ---
# Set to true only if certificates are present in the certs folder
USE_HTTPS=false
SSL_KEY_PATH=./certs/key.pem
SSL_CERT_PATH=./certs/cert.pem

# --- Internal Trigger Configuration ---
INTERNAL_TRIGGER_ENABLED=true
INTERNAL_TRIGGER_SECRET=your_internal_trigger_secret
INTERNAL_TRIGGER_ENDPOINT=/api/internal/trigger